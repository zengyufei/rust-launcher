import { ComboBox, HorizontalBox, LineEdit, ListView, VerticalBox } from "std-widgets.slint";
import { PlanRow, SequenceRow, InspectorRow, LogRow } from "models.slint";
import { LabelText, Panel, PlanMenuRow, PrimaryMiniButton, SectionTitle, SelectableText } from "components.slint";
import { ModalLayer } from "dialogs.slint";

export component AppWindow inherits Window {
    preferred-width: 1440px;
    preferred-height: 960px;
    min-width: 1180px;
    min-height: 640px;
    max-width: 100000px;
    max-height: 100000px;
    title: "Rust 启动器";
    default-font-family: "Microsoft YaHei UI";

    in property <string> data-dir;
    in property <string> selected-plan-title;
    in property <string> selected-plan-file;
    in property <bool> selected-plan-enabled;
    in property <bool> running;
    in property <[PlanRow]> plan-rows;
    in property <[SequenceRow]> sequence-rows;
    in property <bool> has-selection;
    in property <string> selection-summary;
    in property <[InspectorRow]> launch-rows;
    in property <bool> schedule-visible;
    in property <[InspectorRow]> schedule-rows;
    in property <[LogRow]> log-rows;
    in property <bool> context-menu-visible;
    in property <string> context-plan-id;
    in property <bool> context-plan-enabled;
    in property <string> modal-kind;
    in property <string> modal-plan-id;
    in property <string> modal-node-id;
    in property <string> modal-plan-name;
    in property <string> modal-plan-file;
    in property <string> modal-error;
    in property <string> import-conflict-name;
    in property <string> import-conflict-file;
    in property <string> import-conflict-source;
    in-out property <string> create-plan-name;
    in-out property <string> create-plan-id;
    in-out property <string> create-plan-file;
    in-out property <string> rename-plan-name;
    in-out property <string> search-query;
    in-out property <string> item-form-kind;
    in-out property <string> item-form-id;
    in-out property <string> item-form-name;
    in-out property <string> item-form-description;
    in-out property <string> item-form-target;
    in-out property <string> item-form-args;
    in-out property <string> item-form-working-dir;
    in-out property <string> item-form-shell;
    in-out property <string> group-form-id;
    in-out property <string> group-form-name;
    in-out property <string> group-form-description;
    in-out property <string> form-pre-delay-ms;
    in-out property <string> form-post-delay-ms;
    in-out property <string> form-on-failure;
    in-out property <string> schedule-form-index;
    in-out property <string> schedule-form-kind;
    in-out property <string> schedule-form-time;
    in-out property <string> schedule-form-weekday;
    in-out property <string> schedule-form-at;

    callback select-plan(string);
    callback select-node(string);
    callback run-selected();
    callback search-changed(string);
    callback unavailable(string);
    callback open-create-plan();
    callback open-import-plan();
    callback open-plan-menu(string);
    callback close-plan-menu();
    callback plan-menu-action(string, string);
    callback close-modal();
    callback create-plan(string, string, string);
    callback rename-plan(string, string);
    callback delete-plan(string);
    callback confirm-import-overwrite();
    callback open-add-item();
    callback open-edit-node(string);
    callback item-kind-changed(string);
    callback save-item(string, string, string, string, string, string, string, string, string, string, string);
    callback save-group(string, string, string, string, string, string);
    callback set-failure-policy(string);
    callback set-command-shell(string);
    callback set-launch-trigger(string);
    callback open-schedule-modal();
    callback schedule-kind-changed(string);
    callback edit-schedule(string);
    callback delete-schedule(string);
    callback save-schedule(string, string, string, string, string);
    callback bulk-action(string);

    background: #f7f8fb;

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 86px;
            vertical-stretch: 0;
            background: #ffffff;
            border-color: #e3e8f0;
            border-width: 1px;

            HorizontalBox {
                padding: 18px;
                spacing: 16px;

                VerticalBox {
                    spacing: 6px;
                    SelectableText {
                        text: "Rust 启动器";
                        text-size: 26px;
                        text-weight: 700;
                        text-color: #182033;
                        height: 32px;
                    }
                    SelectableText {
                        text: "JSON 驱动的快速启动与方案编排";
                        text-size: 14px;
                        text-color: #60708a;
                        height: 20px;
                    }
                }

                Rectangle {
                    width: 116px;
                    height: 38px;
                    background: (root.running || !root.selected-plan-enabled) ? #cbd5e1 : (run-touch.pressed ? #1557b8 : (run-touch.has-hover ? #2f7df1 : #1f6feb));
                    border-radius: 6px;

                    Image {
                        x: 16px;
                        y: 11px;
                        width: 16px;
                        height: 16px;
                        source: @image-url("icons/rocket-white.svg");
                    }

                    Text {
                        x: 40px;
                        width: parent.width - 48px;
                        text: root.running ? "运行中..." : (!root.selected-plan-enabled ? "已禁用" : "运行方案");
                        color: #ffffff;
                        font-size: 14px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    run-touch := TouchArea {
                        enabled: !root.running && root.selected-plan-enabled;
                        clicked => {
                            root.run-selected();
                        }
                    }
                }
            }
        }

        HorizontalBox {
            padding: 18px;
            spacing: 14px;
            vertical-stretch: 1;

            Panel {
                width: 286px;
                vertical-stretch: 1;

                VerticalBox {
                    padding: 14px;
                    spacing: 12px;

                    HorizontalBox {
                        spacing: 8px;
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("icons/layout-list.svg");
                        }
                        SectionTitle {
                            text: "方案";
                            horizontal-stretch: 1;
                        }
                    }

                    Rectangle {
                        height: 38px;
                        background: #f4f6fa;
                        border-color: #e0e6ef;
                        border-width: 1px;
                        border-radius: 6px;

                        LineEdit {
                            x: 36px;
                            y: 1px;
                            width: parent.width - 44px;
                            height: 36px;
                            text <=> root.search-query;
                            placeholder-text: "搜索方案或启动项";
                            font-size: 13px;
                            edited(query) => {
                                root.search-changed(query);
                            }
                        }
                        Image {
                            x: 12px;
                            y: 11px;
                            width: 16px;
                            height: 16px;
                            source: @image-url("icons/search.svg");
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        horizontal-stretch: 1;
                        clip: true;

                        ListView {
                            width: parent.width;
                            height: parent.height;
                            vertical-scrollbar-policy: as-needed;
                            horizontal-scrollbar-policy: always-off;
                            for row in root.plan-rows: Rectangle {
                                height: 62px;
                                background: row.selected ? #eaf3ff : (plan-touch.has-hover ? #f8fbff : #ffffff);
                                border-color: row.selected ? #8eb8f5 : (plan-touch.has-hover ? #bfd8f4 : #e6ebf2);
                                border-width: 1px;
                                border-radius: 7px;

                                Image {
                                    x: 10px;
                                    y: 11px;
                                    width: 16px;
                                    height: 16px;
                                    source: @image-url("icons/briefcase.svg");
                                }
                                Text {
                                    x: 34px;
                                    y: 9px;
                                    width: parent.width - 46px;
                                    text: row.id + "  " + row.name;
                                    color: row.enabled ? #263247 : #8a94a6;
                                    font-size: 14px;
                                    font-weight: 600;
                                    overflow: elide;
                                }
                                Text {
                                    x: 12px;
                                    y: 36px;
                                    width: parent.width - 24px;
                                    text: row.meta;
                                    color: #60708a;
                                    font-size: 11px;
                                    overflow: elide;
                                }

                                plan-touch := TouchArea {
                                    clicked => {
                                        root.select-plan(row.id);
                                    }
                                    pointer-event(event) => {
                                        if event.button == PointerEventButton.right && event.kind == PointerEventKind.up {
                                            root.open-plan-menu(row.id);
                                        }
                                    }
                                }
                            }
                        }
                    }

                    HorizontalBox {
                        height: 34px;
                        spacing: 10px;
                        PrimaryMiniButton {
                            text: "新建方案";
                            width: 124px;
                            enabled: !root.running;
                            clicked => { root.open-create-plan(); }
                        }
                        PrimaryMiniButton {
                            text: "导入方案";
                            icon: @image-url("icons/import-white.svg");
                            width: 124px;
                            enabled: !root.running;
                            clicked => { root.open-import-plan(); }
                        }
                    }
                }
            }

            Panel {
                horizontal-stretch: 1;
                vertical-stretch: 1;

                VerticalBox {
                    padding: 14px;
                    spacing: 12px;

                    HorizontalBox {
                        spacing: 10px;
                        VerticalBox {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            HorizontalBox {
                                spacing: 10px;
                                Image {
                                    width: 20px;
                                    height: 20px;
                                    source: @image-url("icons/workflow.svg");
                                }
                                SectionTitle { text: root.selected-plan-title; }
                            }
                            LabelText { text: "方案结构"; }
                        }

                        PrimaryMiniButton {
                            text: "新增启动项";
                            width: 112px;
                            clicked => { root.open-add-item(); }
                        }
                    }

                    Rectangle {
                        height: 42px;
                        background: #f7f8fb;
                        border-color: #e3e8f0;
                        border-width: 1px;
                        border-radius: 6px;
                        SelectableText {
                            x: 40px;
                            y: 12px;
                            width: parent.width - 52px;
                            height: parent.height - 24px;
                            text: root.selected-plan-file;
                            text-color: #263247;
                            text-size: 13px;
                            vertical-alignment: center;
                        }
                        Image {
                            x: 14px;
                            y: 13px;
                            width: 16px;
                            height: 16px;
                            source: @image-url("icons/braces.svg");
                        }
                    }

                    if root.has-selection: Rectangle {
                        height: 42px;
                        background: #eef4ff;
                        border-color: #bfd8f4;
                        border-width: 1px;
                        border-radius: 7px;

                        HorizontalBox {
                            padding: 6px;
                            spacing: 8px;
                            Text {
                                text: root.selection-summary;
                                color: #1c5fa8;
                                font-size: 13px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Rectangle {
                                width: 62px;
                                height: 30px;
                                background: bulk-delete-touch.pressed ? #ffd6d6 : (bulk-delete-touch.has-hover ? #ffe4e4 : #fff0f0);
                                border-color: bulk-delete-touch.has-hover ? #e79a9a : #f0b8b8;
                                border-width: 1px;
                                border-radius: 6px;
                                Image {
                                    x: 9px;
                                    y: 8px;
                                    width: 13px;
                                    height: 13px;
                                    source: @image-url("icons/trash-red.svg");
                                }
                                Text {
                                    x: 28px;
                                    width: parent.width - 32px;
                                    text: "删除";
                                    color: #a32020;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-delete-touch := TouchArea { clicked => { root.bulk-action("删除"); } }
                            }
                            Rectangle {
                                width: 50px;
                                height: 30px;
                                background: bulk-group-touch.pressed ? #dfeeff : (bulk-group-touch.has-hover ? #eef6ff : #ffffff);
                                border-color: bulk-group-touch.has-hover ? #8eb8f5 : #bfd8f4;
                                border-width: 1px;
                                border-radius: 6px;
                                Text {
                                    text: "组合";
                                    color: #1c5fa8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-group-touch := TouchArea { clicked => { root.bulk-action("组合"); } }
                            }
                            Rectangle {
                                width: 76px;
                                height: 30px;
                                background: bulk-ungroup-touch.pressed ? #dfeeff : (bulk-ungroup-touch.has-hover ? #eef6ff : #ffffff);
                                border-color: bulk-ungroup-touch.has-hover ? #8eb8f5 : #bfd8f4;
                                border-width: 1px;
                                border-radius: 6px;
                                Text {
                                    text: "取消组合";
                                    color: #1c5fa8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-ungroup-touch := TouchArea { clicked => { root.bulk-action("取消组合"); } }
                            }
                            Rectangle {
                                width: 62px;
                                height: 30px;
                                background: bulk-up-touch.pressed ? #dfeeff : (bulk-up-touch.has-hover ? #eef6ff : #ffffff);
                                border-color: bulk-up-touch.has-hover ? #8eb8f5 : #bfd8f4;
                                border-width: 1px;
                                border-radius: 6px;
                                Image {
                                    x: 9px;
                                    y: 8px;
                                    width: 13px;
                                    height: 13px;
                                    source: @image-url("icons/arrow-up-blue.svg");
                                }
                                Text {
                                    x: 28px;
                                    width: parent.width - 32px;
                                    text: "上移";
                                    color: #1c5fa8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-up-touch := TouchArea { clicked => { root.bulk-action("上移"); } }
                            }
                            Rectangle {
                                width: 62px;
                                height: 30px;
                                background: bulk-down-touch.pressed ? #dfeeff : (bulk-down-touch.has-hover ? #eef6ff : #ffffff);
                                border-color: bulk-down-touch.has-hover ? #8eb8f5 : #bfd8f4;
                                border-width: 1px;
                                border-radius: 6px;
                                Image {
                                    x: 9px;
                                    y: 8px;
                                    width: 13px;
                                    height: 13px;
                                    source: @image-url("icons/arrow-down-blue.svg");
                                }
                                Text {
                                    x: 28px;
                                    width: parent.width - 32px;
                                    text: "下移";
                                    color: #1c5fa8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-down-touch := TouchArea { clicked => { root.bulk-action("下移"); } }
                            }
                            Rectangle {
                                width: 50px;
                                height: 30px;
                                background: bulk-top-touch.pressed ? #dfeeff : (bulk-top-touch.has-hover ? #eef6ff : #ffffff);
                                border-color: bulk-top-touch.has-hover ? #8eb8f5 : #bfd8f4;
                                border-width: 1px;
                                border-radius: 6px;
                                Text {
                                    text: "置顶";
                                    color: #1c5fa8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-top-touch := TouchArea { clicked => { root.bulk-action("置顶"); } }
                            }
                            Rectangle {
                                width: 50px;
                                height: 30px;
                                background: bulk-bottom-touch.pressed ? #dfeeff : (bulk-bottom-touch.has-hover ? #eef6ff : #ffffff);
                                border-color: bulk-bottom-touch.has-hover ? #8eb8f5 : #bfd8f4;
                                border-width: 1px;
                                border-radius: 6px;
                                Text {
                                    text: "置底";
                                    color: #1c5fa8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-bottom-touch := TouchArea { clicked => { root.bulk-action("置底"); } }
                            }
                        }
                    }

                    ListView {
                        height: root.has-selection ? 446px : 500px;
                        vertical-stretch: 0;
                        for row in root.sequence-rows: row-frame := Rectangle {
                            height: row.kind == "group" ? 216px : 116px;
                            background: #ffffff;

                            card := Rectangle {
                                x: 0px;
                                y: 0px;
                                width: parent.width;
                                height: row.kind == "group" ? 206px : 106px;
                                background: row.selected ? #eef4ff : (row-touch.has-hover ? (row.kind == "group" ? #fff2dc : #f8fbff) : (row.kind == "group" ? #fff7ea : #ffffff));
                                border-color: row.selected ? #9ec7f4 : (row-touch.has-hover ? (row.kind == "group" ? #e7bd78 : #bfd8f4) : (row.kind == "group" ? #f0d1a1 : #dde4ee));
                                border-width: 1px;
                                border-radius: 8px;

                                row-touch := TouchArea {
                                    clicked => {
                                        root.select-node(row.id);
                                    }
                                }

                                Rectangle {
                                    x: 12px;
                                    y: 14px;
                                    width: 18px;
                                    height: 18px;
                                    background: row.selected ? #1f6feb : (row-touch.has-hover ? #f8fbff : #ffffff);
                                    border-color: row.selected ? #1f6feb : (row-touch.has-hover ? #7aaeea : #b7c2d0);
                                    border-width: 1px;
                                    border-radius: 4px;
                                    if row.selected: Rectangle {
                                        x: 5px;
                                        y: 5px;
                                        width: 8px;
                                        height: 8px;
                                        background: #ffffff;
                                        border-radius: 2px;
                                    }
                                }

                                Rectangle {
                                    x: 42px;
                                    y: 12px;
                                    width: row.kind == "group" ? 58px : 54px;
                                    height: 24px;
                                    background: row.kind == "group" ? #fff4e3 : (row.kind_label == "路径" ? #eaf3ff : #f2f5f9);
                                    border-color: row.kind == "group" ? #f0d1a1 : (row.kind_label == "路径" ? #bfd8f4 : #d8dee8);
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        text: row.kind_label;
                                        color: row.kind == "group" ? #92400e : #1d4ed8;
                                        font-size: 11px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Text {
                                    x: row.kind == "group" ? 110px : 106px;
                                    y: 13px;
                                    width: parent.width - (row.kind == "group" ? 306px : 292px);
                                    height: 22px;
                                    text: row.title;
                                    color: #182033;
                                    font-size: 14px;
                                    font-weight: 700;
                                    overflow: elide;
                                    vertical-alignment: center;
                                }

                                Rectangle {
                                    x: parent.width - (row.failure == "stop" ? 154px : 168px);
                                    y: 12px;
                                    width: row.failure == "stop" ? 64px : 78px;
                                    height: 24px;
                                    background: row.failure == "stop" ? #fff0f0 : #eaf7ef;
                                    border-color: row.failure == "stop" ? #f0b8b8 : #bfe3cc;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        text: row.failure == "stop" ? "停止" : "继续";
                                        color: row.failure == "stop" ? #a32020 : #166534;
                                        font-size: 11px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                    x: parent.width - 78px;
                                    y: 10px;
                                    width: row.kind == "group" ? 66px : 58px;
                                    height: 32px;
                                    background: edit-touch.pressed ? (row.kind == "group" ? #ffe3b3 : #dfe7f2) : (edit-touch.has-hover ? (row.kind == "group" ? #ffeacc : #e8eef7) : (row.kind == "group" ? #fff4e3 : #f2f5f9));
                                    border-color: edit-touch.has-hover ? (row.kind == "group" ? #e7bd78 : #b7c2d0) : (row.kind == "group" ? #f0d1a1 : #d8dee8);
                                    border-width: 1px;
                                    border-radius: 6px;
                                    Image {
                                        x: row.kind == "group" ? 8px : 9px;
                                        y: 9px;
                                        width: 14px;
                                        height: 14px;
                                        source: @image-url("icons/pencil.svg");
                                    }
                                    Text {
                                        x: row.kind == "group" ? 26px : 26px;
                                        width: parent.width - 30px;
                                        text: row.kind == "group" ? "编辑组" : "编辑";
                                        color: row.kind == "group" ? #805000 : #263247;
                                        font-size: 12px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    edit-touch := TouchArea {
                                        clicked => {
                                            root.open-edit-node(row.id);
                                        }
                                    }
                                }

                                Text {
                                    x: 42px;
                                    y: 44px;
                                    width: parent.width - 120px;
                                    height: 18px;
                                    text: row.description;
                                    color: row.kind == "group" ? #805000 : #60708a;
                                    font-size: 12px;
                                    overflow: elide;
                                }

                                if row.kind == "group": Rectangle {
                                    x: 42px;
                                    y: 68px;
                                    width: parent.width - 120px;
                                    height: 42px;
                                    background: #ffffff;
                                    border-color: #f0d1a1;
                                    border-width: 1px;
                                    border-radius: 6px;
                                    Rectangle {
                                        x: 8px;
                                        y: 15px;
                                        width: 12px;
                                        height: 12px;
                                        background: #805000;
                                        border-radius: 3px;
                                    }
                                    Text {
                                        x: 28px;
                                        y: 4px;
                                        width: parent.width - 36px;
                                        height: 16px;
                                        text: row.child_primary_title;
                                        color: #805000;
                                        font-size: 10px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    Text {
                                        x: 28px;
                                        y: 22px;
                                        width: parent.width - 36px;
                                        height: 15px;
                                        text: row.child_primary_meta;
                                        color: #805000;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }

                                if row.kind == "group" && row.child_secondary_title != "": Rectangle {
                                    x: 42px;
                                    y: 115px;
                                    width: parent.width - 120px;
                                    height: 42px;
                                    background: #ffffff;
                                    border-color: #f0d1a1;
                                    border-width: 1px;
                                    border-radius: 6px;
                                    Rectangle {
                                        x: 8px;
                                        y: 15px;
                                        width: 12px;
                                        height: 12px;
                                        background: #805000;
                                        border-radius: 3px;
                                    }
                                    Text {
                                        x: 28px;
                                        y: 4px;
                                        width: parent.width - 36px;
                                        height: 16px;
                                        text: row.child_secondary_title;
                                        color: #805000;
                                        font-size: 10px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    Text {
                                        x: 28px;
                                        y: 22px;
                                        width: parent.width - 36px;
                                        height: 15px;
                                        text: row.child_secondary_meta;
                                        color: #805000;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }

                                if row.kind == "group" && row.child_more != "": Text {
                                    x: 42px;
                                    y: 160px;
                                    width: parent.width - 120px;
                                    height: 14px;
                                    text: row.child_more;
                                    color: #805000;
                                    font-size: 10px;
                                    overflow: elide;
                                }

                                Rectangle {
                                    x: 42px;
                                    y: row.kind == "group" ? 176px : 72px;
                                    width: row.kind == "group" ? 182px : 138px;
                                    height: 24px;
                                    background: row.kind == "group" ? #ffffff : #f7f8fb;
                                    border-color: row.kind == "group" ? #f0d1a1 : #e3e8f0;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 8px;
                                        width: parent.width - 16px;
                                        height: parent.height;
                                        text: row.delay;
                                        color: #334155;
                                        font-size: 11px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }

                                Rectangle {
                                    x: row.kind == "group" ? 234px : 190px;
                                    y: row.kind == "group" ? 176px : 72px;
                                    width: parent.width - (row.kind == "group" ? 312px : 268px);
                                    height: 24px;
                                    background: row.kind == "group" ? #ffffff : #f7f8fb;
                                    border-color: row.kind == "group" ? #f0d1a1 : #e3e8f0;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 8px;
                                        width: parent.width - 16px;
                                        height: parent.height;
                                        text: row.target;
                                        color: #334155;
                                        font-size: 11px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            Panel {
                width: 338px;
                vertical-stretch: 1;

                VerticalBox {
                    padding: 14px;
                    spacing: 10px;

                    HorizontalBox {
                        spacing: 8px;
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("icons/sliders.svg");
                        }
                        SectionTitle { text: "属性与启动方式"; }
                    }

                    Rectangle {
                        background: #ffffff;
                        border-color: #e3e8f0;
                        border-width: 1px;
                        border-radius: 8px;
                        height: 154px;

                        VerticalBox {
                            padding: 12px;
                            spacing: 7px;
                            SelectableText {
                                text: "方案启动";
                                text-color: #182033;
                                text-size: 14px;
                                text-weight: 700;
                                height: 20px;
                            }
                            SelectableText {
                                text: "点击任一启动方式可修改";
                                text-color: #60708a;
                                text-size: 11px;
                                height: 16px;
                            }
                            for row in root.launch-rows: Rectangle {
                                height: 32px;
                                background: row.value == "selected" ? #eaf3ff : (launch-row-touch.has-hover ? #f8fbff : #f2f5f9);
                                border-color: row.value == "selected" ? #bfd8f4 : (launch-row-touch.has-hover ? #bfd8f4 : #e3e8f0);
                                border-width: 1px;
                                border-radius: 7px;
                                Image {
                                    x: 8px;
                                    y: 8px;
                                    width: 16px;
                                    height: 16px;
                                    source: row.value == "selected" ? @image-url("icons/circle-dot.svg") : @image-url("icons/circle.svg");
                                }
                                Text {
                                    x: 32px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    height: parent.height;
                                    text: row.label;
                                    color: row.value == "selected" ? #1d4ed8 : #334155;
                                    font-size: 13px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                Image {
                                    x: parent.width - 22px;
                                    y: 9px;
                                    width: 14px;
                                    height: 14px;
                                    source: @image-url("icons/chevron-right.svg");
                                }
                                launch-row-touch := TouchArea {
                                    clicked => {
                                        root.set-launch-trigger(row.label);
                                    }
                                }
                            }
                        }
                    }

                    if root.schedule-visible: Rectangle {
                        background: schedule-card-touch.has-hover ? #fff2dc : #fff7ea;
                        border-color: schedule-card-touch.has-hover ? #e7bd78 : #f0d1a1;
                        border-width: 1px;
                        border-radius: 8px;
                        min-height: 138px;
                        vertical-stretch: 1;

                        VerticalBox {
                            padding: 12px;
                            spacing: 7px;
                            HorizontalBox {
                                spacing: 8px;
                                Image {
                                    width: 16px;
                                    height: 16px;
                                    source: @image-url("icons/alarm.svg");
                                }
                                Text {
                                    text: "定时任务";
                                    color: #92400e;
                                    font-size: 14px;
                                    font-weight: 700;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: "编辑";
                                    color: #1d4ed8;
                                    font-size: 12px;
                                    font-weight: 700;
                                }
                            }
                            ListView {
                                vertical-stretch: 1;
                                for row in root.schedule-rows: Rectangle {
                                    height: 28px;
                                    background: #ffffff;
                                    border-color: #f0d1a1;
                                    border-width: 1px;
                                    border-radius: 7px;
                                    Text {
                                        x: 8px;
                                        y: 6px;
                                        width: parent.width - 16px;
                                        text: row.value;
                                        color: #334155;
                                        font-size: 12px;
                                        font-weight: 700;
                                        overflow: elide;
                                    }
                                }
                            }
                            SelectableText {
                                text: "仅在应用启动自动时显示并生效。";
                                text-color: #805000;
                                text-size: 11px;
                                height: 16px;
                            }
                        }

                        schedule-card-touch := TouchArea {
                            enabled: !root.running;
                            clicked => {
                                root.open-schedule-modal();
                            }
                        }
                    }

                    Rectangle {
                        background: #f7f8fb;
                        border-color: #e3e8f0;
                        border-width: 1px;
                        border-radius: 8px;
                        height: 132px;

                        VerticalBox {
                            padding: 12px;
                            spacing: 7px;
                            HorizontalBox {
                                spacing: 8px;
                                Image {
                                    width: 16px;
                                    height: 16px;
                                    source: @image-url("icons/braces.svg");
                                }
                                SelectableText {
                                    text: "JSON 存储";
                                    text-color: #182033;
                                    text-size: 14px;
                                    text-weight: 700;
                                    height: 20px;
                                }
                            }
                            SelectableText {
                                text: "global.json: 全局设置与启动方式";
                                text-color: #263247;
                                text-size: 13px;
                                height: 18px;
                            }
                            SelectableText {
                                text: root.selected-plan-file;
                                text-color: #263247;
                                text-size: 13px;
                                height: 18px;
                            }
                            SelectableText {
                                text: root.data-dir;
                                text-color: #60708a;
                                text-size: 11px;
                                height: 16px;
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 200px;
            vertical-stretch: 0;
            background: #eef4ff;
            border-color: #c7d8f2;
            border-width: 1px;

            VerticalBox {
                padding: 8px;
                spacing: 4px;
                SelectableText {
                    text: "执行日志";
                    text-color: #1f3b64;
                    text-size: 14px;
                    text-weight: 700;
                    height: 20px;
                }
                ListView {
                    height: 154px;
                    vertical-stretch: 0;
                    for row in root.log-rows: Rectangle {
                        height: 24px;
                        background: #00000000;

                        SelectableText {
                            x: 0px;
                            y: 3px;
                            width: parent.width - 10px;
                            height: 18px;
                            text: row.message;
                            text-color: row.level == "error" ? #a32020 : #1f3b64;
                            text-size: 12px;
                        }
                    }
                }
            }
        }
    }

    if root.context-menu-visible: Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        background: #00000000;
        TouchArea {
            clicked => {
                root.close-plan-menu();
            }
        }
    }

    if root.context-menu-visible: Rectangle {
        x: 302px;
        y: 212px;
        width: 184px;
        height: 294px;
        background: #ffffff;
        border-color: #cbd5e1;
        border-width: 1px;
        border-radius: 8px;

        VerticalBox {
            padding: 6px;
            spacing: 2px;

            PlanMenuRow {
                text: "编辑方案";
                icon: @image-url("icons/pencil.svg");
                emphasized: true;
                clicked => { root.plan-menu-action(root.context-plan-id, "编辑方案"); }
            }
            PlanMenuRow {
                text: "导出方案";
                icon: @image-url("icons/export-gray.svg");
                emphasized: true;
                clicked => { root.plan-menu-action(root.context-plan-id, "导出方案"); }
            }
            PlanMenuRow {
                text: "删除方案";
                icon: @image-url("icons/trash-red.svg");
                danger: true;
                emphasized: true;
                clicked => { root.plan-menu-action(root.context-plan-id, "删除方案"); }
            }
            Rectangle {
                height: 1px;
                background: #e2e8f0;
            }
            PlanMenuRow {
                text: "置顶";
                icon: @image-url("icons/chevrons-up-gray.svg");
                clicked => { root.plan-menu-action(root.context-plan-id, "置顶"); }
            }
            PlanMenuRow {
                text: "上移";
                icon: @image-url("icons/chevron-up-gray.svg");
                clicked => { root.plan-menu-action(root.context-plan-id, "上移"); }
            }
            PlanMenuRow {
                text: "下移";
                icon: @image-url("icons/chevron-down-gray.svg");
                clicked => { root.plan-menu-action(root.context-plan-id, "下移"); }
            }
            PlanMenuRow {
                text: "置底";
                icon: @image-url("icons/chevrons-down-gray.svg");
                clicked => { root.plan-menu-action(root.context-plan-id, "置底"); }
            }
            Rectangle {
                height: 1px;
                background: #e2e8f0;
            }
            PlanMenuRow {
                text: root.context-plan-enabled ? "禁用方案" : "启用方案";
                icon: @image-url("icons/power-off-gray.svg");
                clicked => { root.plan-menu-action(root.context-plan-id, root.context-plan-enabled ? "禁用方案" : "启用方案"); }
            }
        }
    }

    ModalLayer {
        width: root.width;
        height: root.height;
        running: root.running;
        modal-kind: root.modal-kind;
        modal-plan-id: root.modal-plan-id;
        modal-plan-name: root.modal-plan-name;
        modal-plan-file: root.modal-plan-file;
        modal-error: root.modal-error;
        import-conflict-name: root.import-conflict-name;
        import-conflict-file: root.import-conflict-file;
        import-conflict-source: root.import-conflict-source;
        schedule-rows: root.schedule-rows;
        create-plan-name <=> root.create-plan-name;
        create-plan-id <=> root.create-plan-id;
        create-plan-file <=> root.create-plan-file;
        rename-plan-name <=> root.rename-plan-name;
        item-form-kind <=> root.item-form-kind;
        item-form-id <=> root.item-form-id;
        item-form-name <=> root.item-form-name;
        item-form-description <=> root.item-form-description;
        item-form-target <=> root.item-form-target;
        item-form-args <=> root.item-form-args;
        item-form-working-dir <=> root.item-form-working-dir;
        item-form-shell <=> root.item-form-shell;
        group-form-id <=> root.group-form-id;
        group-form-name <=> root.group-form-name;
        group-form-description <=> root.group-form-description;
        form-pre-delay-ms <=> root.form-pre-delay-ms;
        form-post-delay-ms <=> root.form-post-delay-ms;
        form-on-failure <=> root.form-on-failure;
        schedule-form-index <=> root.schedule-form-index;
        schedule-form-kind <=> root.schedule-form-kind;
        schedule-form-time <=> root.schedule-form-time;
        schedule-form-weekday <=> root.schedule-form-weekday;
        schedule-form-at <=> root.schedule-form-at;
        close-modal => { root.close-modal(); }
        create-plan(name, id, file) => { root.create-plan(name, id, file); }
        rename-plan(id, name) => { root.rename-plan(id, name); }
        delete-plan(id) => { root.delete-plan(id); }
        confirm-import-overwrite => { root.confirm-import-overwrite(); }
        item-kind-changed(kind) => { root.item-kind-changed(kind); }
        save-item(id, name, description, kind, target, args, working-dir, shell, pre-delay, post-delay, on-failure) => { root.save-item(id, name, description, kind, target, args, working-dir, shell, pre-delay, post-delay, on-failure); }
        save-group(id, name, description, pre-delay, post-delay, on-failure) => { root.save-group(id, name, description, pre-delay, post-delay, on-failure); }
        set-failure-policy(policy) => { root.set-failure-policy(policy); }
        set-command-shell(shell) => { root.set-command-shell(shell); }
        schedule-kind-changed(kind) => { root.schedule-kind-changed(kind); }
        edit-schedule(index) => { root.edit-schedule(index); }
        delete-schedule(index) => { root.delete-schedule(index); }
        save-schedule(index, kind, time, weekday, at) => { root.save-schedule(index, kind, time, weekday, at); }
    }
}
