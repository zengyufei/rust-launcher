import { HorizontalBox, ListView, VerticalBox } from "std-widgets.slint";
import { SequenceRow } from "models.slint";
import { LabelText, Panel, PrimaryMiniButton, SectionTitle } from "components.slint";

export component PlanStructurePanel inherits Panel {
    in property <string> selected-plan-title;
    in property <string> selected-plan-file;
    in property <bool> has-selection;
    in property <string> selection-summary;
    in property <[SequenceRow]> sequence-rows;

    callback open-add-item();
    callback bulk-action(string);
    callback select-node(string, string);
    callback open-edit-node(string);

    horizontal-stretch: 1;
    vertical-stretch: 1;


                VerticalBox {
                    padding: 14px;
                    spacing: 12px;

                    HorizontalBox {
                        spacing: 10px;
                        VerticalBox {
                            spacing: 4px;
                            horizontal-stretch: 1;
                            HorizontalBox {
                                spacing: 10px;
                                Image {
                                    width: 20px;
                                    height: 20px;
                                    source: @image-url("icons/workflow.svg");
                                }
                                SectionTitle { text: root.selected-plan-title; }
                            }
                            LabelText { text: "方案结构"; }
                        }

                        PrimaryMiniButton {
                            text: "新增启动项";
                            width: 112px;
                            clicked => { root.open-add-item(); }
                        }
                    }

                    Rectangle {
                        height: 42px;
                        background: root.has-selection ? #eef4ff : #f7f8fb;
                        border-color: root.has-selection ? #bfd8f4 : #e3e8f0;
                        border-width: 1px;
                        border-radius: 7px;

                        HorizontalBox {
                            padding: 6px;
                            spacing: 8px;
                            Text {
                                text: root.has-selection ? root.selection-summary : "未选择启动项";
                                color: root.has-selection ? #1c5fa8 : #60708a;
                                font-size: 13px;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Rectangle {
                                width: 62px;
                                height: 30px;
                                background: !root.has-selection ? #f8fafc : (bulk-delete-touch.pressed ? #ffd6d6 : (bulk-delete-touch.has-hover ? #ffe4e4 : #fff0f0));
                                border-color: !root.has-selection ? #d7dde6 : (bulk-delete-touch.has-hover ? #e79a9a : #f0b8b8);
                                border-width: 1px;
                                border-radius: 6px;
                                Image {
                                    x: 9px;
                                    y: 8px;
                                    width: 13px;
                                    height: 13px;
                                    source: @image-url("icons/trash-red.svg");
                                    colorize: root.has-selection ? #00000000 : #94a3b8;
                                }
                                Text {
                                    x: 28px;
                                    width: parent.width - 32px;
                                    text: "删除";
                                    color: root.has-selection ? #a32020 : #94a3b8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-delete-touch := TouchArea { enabled: root.has-selection; clicked => { root.bulk-action("删除"); } }
                            }
                            Rectangle {
                                width: 50px;
                                height: 30px;
                                background: !root.has-selection ? #f8fafc : (bulk-group-touch.pressed ? #dfeeff : (bulk-group-touch.has-hover ? #eef6ff : #ffffff));
                                border-color: !root.has-selection ? #d7dde6 : (bulk-group-touch.has-hover ? #8eb8f5 : #bfd8f4);
                                border-width: 1px;
                                border-radius: 6px;
                                Text {
                                    text: "组合";
                                    color: root.has-selection ? #1c5fa8 : #94a3b8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-group-touch := TouchArea { enabled: root.has-selection; clicked => { root.bulk-action("组合"); } }
                            }
                            Rectangle {
                                width: 76px;
                                height: 30px;
                                background: !root.has-selection ? #f8fafc : (bulk-ungroup-touch.pressed ? #dfeeff : (bulk-ungroup-touch.has-hover ? #eef6ff : #ffffff));
                                border-color: !root.has-selection ? #d7dde6 : (bulk-ungroup-touch.has-hover ? #8eb8f5 : #bfd8f4);
                                border-width: 1px;
                                border-radius: 6px;
                                Text {
                                    text: "取消组合";
                                    color: root.has-selection ? #1c5fa8 : #94a3b8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-ungroup-touch := TouchArea { enabled: root.has-selection; clicked => { root.bulk-action("取消组合"); } }
                            }
                            Rectangle {
                                width: 62px;
                                height: 30px;
                                background: !root.has-selection ? #f8fafc : (bulk-up-touch.pressed ? #dfeeff : (bulk-up-touch.has-hover ? #eef6ff : #ffffff));
                                border-color: !root.has-selection ? #d7dde6 : (bulk-up-touch.has-hover ? #8eb8f5 : #bfd8f4);
                                border-width: 1px;
                                border-radius: 6px;
                                Image {
                                    x: 9px;
                                    y: 8px;
                                    width: 13px;
                                    height: 13px;
                                    source: @image-url("icons/arrow-up-blue.svg");
                                    colorize: root.has-selection ? #00000000 : #94a3b8;
                                }
                                Text {
                                    x: 28px;
                                    width: parent.width - 32px;
                                    text: "上移";
                                    color: root.has-selection ? #1c5fa8 : #94a3b8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-up-touch := TouchArea { enabled: root.has-selection; clicked => { root.bulk-action("上移"); } }
                            }
                            Rectangle {
                                width: 62px;
                                height: 30px;
                                background: !root.has-selection ? #f8fafc : (bulk-down-touch.pressed ? #dfeeff : (bulk-down-touch.has-hover ? #eef6ff : #ffffff));
                                border-color: !root.has-selection ? #d7dde6 : (bulk-down-touch.has-hover ? #8eb8f5 : #bfd8f4);
                                border-width: 1px;
                                border-radius: 6px;
                                Image {
                                    x: 9px;
                                    y: 8px;
                                    width: 13px;
                                    height: 13px;
                                    source: @image-url("icons/arrow-down-blue.svg");
                                    colorize: root.has-selection ? #00000000 : #94a3b8;
                                }
                                Text {
                                    x: 28px;
                                    width: parent.width - 32px;
                                    text: "下移";
                                    color: root.has-selection ? #1c5fa8 : #94a3b8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-down-touch := TouchArea { enabled: root.has-selection; clicked => { root.bulk-action("下移"); } }
                            }
                            Rectangle {
                                width: 50px;
                                height: 30px;
                                background: !root.has-selection ? #f8fafc : (bulk-top-touch.pressed ? #dfeeff : (bulk-top-touch.has-hover ? #eef6ff : #ffffff));
                                border-color: !root.has-selection ? #d7dde6 : (bulk-top-touch.has-hover ? #8eb8f5 : #bfd8f4);
                                border-width: 1px;
                                border-radius: 6px;
                                Text {
                                    text: "置顶";
                                    color: root.has-selection ? #1c5fa8 : #94a3b8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-top-touch := TouchArea { enabled: root.has-selection; clicked => { root.bulk-action("置顶"); } }
                            }
                            Rectangle {
                                width: 50px;
                                height: 30px;
                                background: !root.has-selection ? #f8fafc : (bulk-bottom-touch.pressed ? #dfeeff : (bulk-bottom-touch.has-hover ? #eef6ff : #ffffff));
                                border-color: !root.has-selection ? #d7dde6 : (bulk-bottom-touch.has-hover ? #8eb8f5 : #bfd8f4);
                                border-width: 1px;
                                border-radius: 6px;
                                Text {
                                    text: "置底";
                                    color: root.has-selection ? #1c5fa8 : #94a3b8;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                bulk-bottom-touch := TouchArea { enabled: root.has-selection; clicked => { root.bulk-action("置底"); } }
                            }
                        }
                    }

                    ListView {
                        height: 500px;
                        vertical-stretch: 0;
                        for row in root.sequence-rows: row-frame := Rectangle {
                            height: row.kind == "group" ? 216px : 116px;
                            background: #ffffff;

                            card := Rectangle {
                                x: 0px;
                                y: 0px;
                                width: parent.width;
                                height: row.kind == "group" ? 206px : 106px;
                                background: row.selected ? #eef4ff : (row-touch.has-hover ? (row.kind == "group" ? #fff2dc : #f8fbff) : (row.kind == "group" ? #fff7ea : #ffffff));
                                border-color: row.selected ? #9ec7f4 : (row-touch.has-hover ? (row.kind == "group" ? #e7bd78 : #bfd8f4) : (row.kind == "group" ? #f0d1a1 : #dde4ee));
                                border-width: 1px;
                                border-radius: 8px;

                                Rectangle {
                                    x: 12px;
                                    y: 14px;
                                    width: 18px;
                                    height: 18px;
                                    background: row.selected ? #1f6feb : (row-touch.has-hover ? #f8fbff : #ffffff);
                                    border-color: row.selected ? #1f6feb : (row-touch.has-hover ? #7aaeea : #b7c2d0);
                                    border-width: 1px;
                                    border-radius: 4px;
                                    if row.selected: Rectangle {
                                        x: 5px;
                                        y: 5px;
                                        width: 8px;
                                        height: 8px;
                                        background: #ffffff;
                                        border-radius: 2px;
                                    }
                                    checkbox-touch := TouchArea {
                                        clicked => {
                                            root.select-node(row.id, "toggle");
                                        }
                                    }
                                }

                                row-touch := TouchArea {
                                    x: 36px;
                                    y: 0px;
                                    width: parent.width - 36px;
                                    height: parent.height;
                                    pointer-event(event) => {
                                        if event.button == PointerEventButton.left && event.kind == PointerEventKind.up {
                                            root.select-node(row.id, event.modifiers.shift ? "extend" : "replace");
                                        }
                                    }
                                }

                                Rectangle {
                                    x: 42px;
                                    y: 12px;
                                    width: row.kind == "group" ? 58px : 54px;
                                    height: 24px;
                                    background: row.kind == "group" ? #fff4e3 : (row.kind_label == "路径" ? #eaf3ff : #f2f5f9);
                                    border-color: row.kind == "group" ? #f0d1a1 : (row.kind_label == "路径" ? #bfd8f4 : #d8dee8);
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        text: row.kind_label;
                                        color: row.kind == "group" ? #92400e : #1d4ed8;
                                        font-size: 11px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Text {
                                    x: row.kind == "group" ? 110px : 106px;
                                    y: 13px;
                                    width: parent.width - (row.kind == "group" ? 306px : 292px);
                                    height: 22px;
                                    text: row.title;
                                    color: #182033;
                                    font-size: 14px;
                                    font-weight: 700;
                                    overflow: elide;
                                    vertical-alignment: center;
                                }

                                Rectangle {
                                    x: parent.width - (row.failure == "stop" ? 154px : 168px);
                                    y: 12px;
                                    width: row.failure == "stop" ? 64px : 78px;
                                    height: 24px;
                                    background: row.failure == "stop" ? #fff0f0 : #eaf7ef;
                                    border-color: row.failure == "stop" ? #f0b8b8 : #bfe3cc;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        text: row.failure == "stop" ? "停止" : "继续";
                                        color: row.failure == "stop" ? #a32020 : #166534;
                                        font-size: 11px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                    x: parent.width - 78px;
                                    y: 10px;
                                    width: row.kind == "group" ? 66px : 58px;
                                    height: 32px;
                                    background: edit-touch.pressed ? (row.kind == "group" ? #ffe3b3 : #dfe7f2) : (edit-touch.has-hover ? (row.kind == "group" ? #ffeacc : #e8eef7) : (row.kind == "group" ? #fff4e3 : #f2f5f9));
                                    border-color: edit-touch.has-hover ? (row.kind == "group" ? #e7bd78 : #b7c2d0) : (row.kind == "group" ? #f0d1a1 : #d8dee8);
                                    border-width: 1px;
                                    border-radius: 6px;
                                    Image {
                                        x: row.kind == "group" ? 8px : 9px;
                                        y: 9px;
                                        width: 14px;
                                        height: 14px;
                                        source: @image-url("icons/pencil.svg");
                                    }
                                    Text {
                                        x: row.kind == "group" ? 26px : 26px;
                                        width: parent.width - 30px;
                                        text: row.kind == "group" ? "编辑组" : "编辑";
                                        color: row.kind == "group" ? #805000 : #263247;
                                        font-size: 12px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    edit-touch := TouchArea {
                                        clicked => {
                                            root.open-edit-node(row.id);
                                        }
                                    }
                                }

                                Text {
                                    x: 42px;
                                    y: 44px;
                                    width: parent.width - 120px;
                                    height: 18px;
                                    text: row.description;
                                    color: row.kind == "group" ? #805000 : #60708a;
                                    font-size: 12px;
                                    overflow: elide;
                                }

                                if row.kind == "group": Rectangle {
                                    x: 42px;
                                    y: 68px;
                                    width: parent.width - 120px;
                                    height: 42px;
                                    background: #ffffff;
                                    border-color: #f0d1a1;
                                    border-width: 1px;
                                    border-radius: 6px;
                                    Rectangle {
                                        x: 8px;
                                        y: 15px;
                                        width: 12px;
                                        height: 12px;
                                        background: #805000;
                                        border-radius: 3px;
                                    }
                                    Text {
                                        x: 28px;
                                        y: 4px;
                                        width: parent.width - 36px;
                                        height: 16px;
                                        text: row.child_primary_title;
                                        color: #805000;
                                        font-size: 10px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    Text {
                                        x: 28px;
                                        y: 22px;
                                        width: parent.width - 36px;
                                        height: 15px;
                                        text: row.child_primary_meta;
                                        color: #805000;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }

                                if row.kind == "group" && row.child_secondary_title != "": Rectangle {
                                    x: 42px;
                                    y: 115px;
                                    width: parent.width - 120px;
                                    height: 42px;
                                    background: #ffffff;
                                    border-color: #f0d1a1;
                                    border-width: 1px;
                                    border-radius: 6px;
                                    Rectangle {
                                        x: 8px;
                                        y: 15px;
                                        width: 12px;
                                        height: 12px;
                                        background: #805000;
                                        border-radius: 3px;
                                    }
                                    Text {
                                        x: 28px;
                                        y: 4px;
                                        width: parent.width - 36px;
                                        height: 16px;
                                        text: row.child_secondary_title;
                                        color: #805000;
                                        font-size: 10px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    Text {
                                        x: 28px;
                                        y: 22px;
                                        width: parent.width - 36px;
                                        height: 15px;
                                        text: row.child_secondary_meta;
                                        color: #805000;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }

                                if row.kind == "group" && row.child_more != "": Text {
                                    x: 42px;
                                    y: 160px;
                                    width: parent.width - 120px;
                                    height: 14px;
                                    text: row.child_more;
                                    color: #805000;
                                    font-size: 10px;
                                    overflow: elide;
                                }

                                Rectangle {
                                    x: 42px;
                                    y: row.kind == "group" ? 176px : 72px;
                                    width: row.kind == "group" ? 182px : 138px;
                                    height: 24px;
                                    background: row.kind == "group" ? #ffffff : #f7f8fb;
                                    border-color: row.kind == "group" ? #f0d1a1 : #e3e8f0;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 8px;
                                        width: parent.width - 16px;
                                        height: parent.height;
                                        text: row.delay;
                                        color: #334155;
                                        font-size: 11px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }

                                Rectangle {
                                    x: row.kind == "group" ? 234px : 190px;
                                    y: row.kind == "group" ? 176px : 72px;
                                    width: parent.width - (row.kind == "group" ? 312px : 268px);
                                    height: 24px;
                                    background: row.kind == "group" ? #ffffff : #f7f8fb;
                                    border-color: row.kind == "group" ? #f0d1a1 : #e3e8f0;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 8px;
                                        width: parent.width - 16px;
                                        height: parent.height;
                                        text: row.target;
                                        color: #334155;
                                        font-size: 11px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
}
