import { ListView, VerticalBox } from "std-widgets.slint";
import { LogRow } from "models.slint";
import { SelectableText } from "components.slint";

export component ExecutionLogPanel inherits Rectangle {
    in property <[LogRow]> log-rows;

    height: 200px;
    vertical-stretch: 0;
    background: #eef4ff;
    border-color: #c7d8f2;
    border-width: 1px;

    VerticalBox {
        padding: 8px;
        spacing: 4px;
        SelectableText {
            text: "执行日志";
            text-color: #1f3b64;
            text-size: 14px;
            text-weight: 700;
            height: 20px;
        }
        ListView {
            height: 154px;
            vertical-stretch: 0;
            for row in root.log-rows: Rectangle {
                height: 24px;
                background: #00000000;

                SelectableText {
                    x: 0px;
                    y: 3px;
                    width: parent.width - 10px;
                    height: 18px;
                    text: row.message;
                    text-color: row.level == "error" ? #a32020 : #1f3b64;
                    text-size: 12px;
                }
            }
        }
    }
}
