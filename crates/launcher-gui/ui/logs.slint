import { TextEdit } from "std-widgets.slint";
import { SelectableText } from "components.slint";

export component ExecutionLogPanel inherits Rectangle {
    in property <string> log-text;

    height: 240px;
    background: #eef4ff;
    border-color: #c7d8f2;
    border-width: 1px;

    SelectableText {
        x: 8px;
        y: 8px;
        width: parent.width - 16px;
        height: 20px;
        text: "执行日志";
        text-color: #1f3b64;
        text-size: 14px;
        text-weight: 700;
    }

    TextEdit {
        x: 8px;
        y: 32px;
        width: parent.width - 16px;
        height: parent.height - 40px;
        text: root.log-text;
        read-only: true;
        wrap: no-wrap;
        font-family: "Microsoft YaHei UI";
        font-size: 12px;
    }
}
